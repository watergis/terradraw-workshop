# API keys baked into the live-editor examples at build time.
# Copy to .env and fill in, then run:
#   uv run python scripts/generate_keys.py
# On Cloudflare Pages, set these as build environment variables instead.
# Restrict the keys by HTTP referrer — the built site is public.

# https://console.mapbox.com/ → Tokens (a default public token works)
MAPBOX_ACCESS_TOKEN=

# https://console.cloud.google.com/ → APIs & Services → Credentials
# (enable "Maps JavaScript API" for the project)
GOOGLE_MAPS_API_KEY=

# https://location.arcgis.com/ → API keys (only needed if the ArcGIS example
# uses a basemap that requires authentication)
ARCGIS_API_KEY=
